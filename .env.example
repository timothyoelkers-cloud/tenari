# ─────────────────────────────────────────────
# Tenari — Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://tenari:tenari@localhost:5432/tenari"

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Object Storage (MinIO locally, Azure Blob in prod) ──
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="tenari"

# ── Auth (NextAuth v5 + Microsoft Entra ID) ───
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Microsoft Entra ID multi-tenant app registration
# See handoff/AZURE_INTEGRATION.md for setup steps
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"   # "common" = multi-tenant

# ── Anthropic (AI Bicep generation) ───────────
ANTHROPIC_API_KEY=""

# ── Email (Resend — optional for v1) ──────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@tenari.io"

# ── Feature flags ──────────────────────────────
NEXT_PUBLIC_APP_NAME="Tenari"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MOCK_DATA="true"   # set to "false" to require real Azure connections
